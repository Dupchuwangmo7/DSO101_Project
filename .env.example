# ============================================================
# AI Math Education — Environment Variables Template
# ============================================================
# NEVER commit .env to git.
# 1. For local dev: copy to .env and fill in values
# 2. For Render:    add each variable in the Render dashboard
# ============================================================

# ── Database ─────────────────────────────────────────────────
DB_HOST=postgres
DB_PORT=5432
DB_USERNAME=aimath_user
DB_PASSWORD=CHANGE_ME_strong_password
DB_DATABASE=education_math_db

# Set to "false" in production on Render (migrations only)
# Set to "true" for first boot / local dev
TYPEORM_SYNC=true

# ── Auth & Security ──────────────────────────────────────────
# Generate with: openssl rand -base64 64
JWT_SECRET=CHANGE_ME_run_openssl_rand_base64_64

# Generate with: openssl rand -base64 32
COOKIE_SECRET=CHANGE_ME_run_openssl_rand_base64_32

# ── CORS ─────────────────────────────────────────────────────
# Local dev:
FRONTEND_ORIGIN=http://localhost:3000
# Render production (update after deploying frontend):
# FRONTEND_ORIGIN=https://aimath-frontend.onrender.com

# ── External APIs ────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
ELEVENLABS_VOICE_ID=your_voice_id_here
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# ── App Config ───────────────────────────────────────────────
PORT=3001
NODE_ENV=production
BODY_LIMIT=25mb

# ── Frontend (baked into Next.js bundle at build time) ───────
# Local dev:
NEXT_PUBLIC_BACKEND_URL=http://localhost:3001
# Render production (update after deploying backend):
# NEXT_PUBLIC_BACKEND_URL=https://aimath-backend.onrender.com

# ── Monitoring (local dev only) ──────────────────────────────
GRAFANA_USER=admin
GRAFANA_PASSWORD=CHANGE_ME_grafana_password

# ── CI/CD Notifications ──────────────────────────────────────
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/XXX/YYY/ZZZ
